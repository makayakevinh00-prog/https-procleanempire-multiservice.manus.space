# Token d'acces System User (Business Settings > System Users), scope ads_management
META_ACCESS_TOKEN=

# ID du compte publicitaire, format act_XXXXXXXXXX (visible dans Ads Manager)
META_AD_ACCOUNT_ID=

# Optionnel: App ID / App Secret (necessaires seulement pour l'echange ou le refresh de token)
META_APP_ID=
META_APP_SECRET=

# Version de l'API Marketing utilisee par le SDK (par defaut la plus recente supportee par le SDK)
META_API_VERSION=v21.0
